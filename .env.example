# =============================================================================
# CDSS Platform — Environment Variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values.
#   cp .env.example .env.local
# NEVER commit `.env.local` (it is gitignored). Keep production secrets in a
# secrets manager (Vercel env, AWS Secrets Manager, etc.), not in source.
# =============================================================================

# --- Database -----------------------------------------------------------------
# MongoDB connection string (Atlas SRV or standard). Include credentials + db name.
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority"

# --- Cloudinary (file / medical image storage) --------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=CDSS

# --- AI diagnosis agent (Mistral) ---------------------------------------------
CDSS_AI_API_KEY=your_ai_api_key
CDSS_AI_AGENT_ID=your_agent_id

# --- Email / OTP (Nodemailer via Gmail app password) --------------------------
EMAIL=your_sender@example.com
# Gmail App Password (16 chars, spaces allowed) — NOT your account password.
EMAIL_APP_PWD=xxxx xxxx xxxx xxxx
# OTP lifetime in minutes.
OTP_EXPIRATION_TIME=5

# --- Auth (NextAuth) ----------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=generate_a_strong_random_secret

# --- Google OAuth -------------------------------------------------------------
# From Google Cloud Console → Credentials → OAuth 2.0 Client ID.
# Authorized redirect URI must be: <origin>/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Runtime ------------------------------------------------------------------
NODE_ENV=development
